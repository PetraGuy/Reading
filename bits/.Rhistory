data = getdata("JoeTestTides.csv")
howmanydays = getnumdays(data)
maxdf = data.frame()
for (i in howmanydays){
singleday = getday(i,data)
maxrow1 = singleday[which.max(singleday$high),]
row_number = as.integer(row.names(maxrow1))
restofday = getrestofday(row_number, singleday)
maxrow2 = restofday[which.max(restofday$high),]
rows = rbind(maxrow1,maxrow2)
orderedrows = rows[order(rows$time),]
maxdf = rbind(maxdf,orderedrows)
}
View(maxdf)
View(maxdf)
View(maxrow1)
View(maxrow2)
