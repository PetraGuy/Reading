normalize <- function(x) {
return ((x - min(x, na.rm = TRUE)) / (max(x, na.rm = TRUE) - min(x, na.rm = TRUE)))
}
normdata = as.data.frame(apply(data,2,normalize))
normdata = normdata[complete.cases(normdata),]
View(normdata)
