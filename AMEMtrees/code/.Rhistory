linearmod = function(data,n){
data = na.omit(data)
data = as.data.frame(apply(data,2, FUN =normalize)) # normalize
y = colnames(data)[1]
x = colnames(data[-1])
xvect = ""
i=1
while (i<n){
xvect = paste(xvect,x[[i]],"+")
i = i+1
}
xvect  = paste(xvect,x[[n]])
lm = reformulate(xvect, y), data = data,na.action = 'na.fail')
return(lm))
}
