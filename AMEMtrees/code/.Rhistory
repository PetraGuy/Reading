dfamnorm = as.data.frame(apply(dfam,2, FUN =normalize))
normalize <- function(x) {
norm = ((x - min(x, na.rm = TRUE)) / (max(x, na.rm = TRUE) - min(x, na.rm = TRUE)))
return(norm)
}
dfam = amplots[-c(1,2,12,13,14)]
