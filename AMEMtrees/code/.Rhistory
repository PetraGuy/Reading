View(scaled)
scaled$inv = scaled$invtreeprop+scaled$percentinvcover
scaled$am = scaled$amtreeprop+scaled$percentamcover
View(emplots)
inv = scaled$invtreeprop+scaled$percentinvcover
am = scaled$amtreeprop+scaled$percentamcover
