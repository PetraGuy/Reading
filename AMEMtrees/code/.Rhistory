}
###########################################################################
#go through all sites and do the above
getsamples = function(siteslist){
#browser()
df = data.frame(matrix(ncol = 5,nrow = length(siteslist)))
colnames(df)= c("alpha","propAMtree", "Propinvtree","propAMcover","propInvcover")
for (n in 1:length(siteslist)){
site = siteslist[[n]]
if (nrow(site)>5){
thisrow = getaves(site)
df[n,] = thisrow
} else if (nrow(site)==5){
thisrow = apply(site[-c(1)], 2, sum)
df[n,] = thisrow
} else {
thisrow = vector(mode = 'numeric', length = 5)
df[n,] = thisrow
}
}
df = df[!apply(df, 1, function(x) all(x == 0)), ]
return(df)
}
